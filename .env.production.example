# Production client build settings.
# If the Node server serves both dist/ and WebSocket on the same domain,
# you can leave VITE_WS_URL unset. The client will auto-use ws(s)://current-host.
#
# Set this only when the WebSocket server is on another host.
# VITE_WS_URL=wss://your-domain.com

# Node production server settings for `npm run start:prod`.
# Keep HOST=127.0.0.1 when using Nginx/Caddy reverse proxy on the same server.
# Use HOST=0.0.0.0 only if you intentionally expose the Node port directly.
PORT=3000
HOST=127.0.0.1
